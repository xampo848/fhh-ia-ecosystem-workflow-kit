{
  "schema_version": "1.0.0",
  "starter_status": true,
  "description": "Installable starter template packs for a portable AI workflow kit. Packs are intentionally neutral and must not embed product-specific FHH IA Ecosystem domain rules.",
  "forbidden_terms_in_portable_or_adapters": [
    "FHH IA Ecosystem measures",
    "analytics_metric",
    "acts_as_tenant",
    "DORA",
    "backend/",
    "front/",
    "Rails 8",
    "React 19"
  ],
  "packs": [
    {
      "id": "repo-overlay-fhh-ia-ecosystem-full",
      "role": "complete FHH IA Ecosystem overlay derived from .agents2",
      "source": "repo-overlay-fhh-ia-ecosystem-full",
      "documentation_only": [
        "README.md"
      ],
      "required_files": [
        ".agents/skills/index.md",
        ".agents/instructions.md",
        ".agents/skills/registry.md",
        ".agents/skills/02-implement/implement-prd/SKILL.md",
        ".agents/skills/06-patterns/README.md",
        ".agents/capabilities/registry.md",
        "docs/workflow/README.md",
        "docs/workflow/standards/setup-and-migration.md"
      ]
    },
    {
      "id": "adapter-agents-md",
      "role": "Shared AGENTS.md bootstrap for compatible agent runtimes",
      "source": "runtime-adapters/agents-md",
      "documentation_only": [],
      "requires_reference": ".agents/instructions.md",
      "required_files": [
        "AGENTS.md"
      ]
    },
    {
      "id": "adapter-codex",
      "role": "Codex thin runtime adapter",
      "source": "runtime-adapters/codex",
      "documentation_only": [],
      "requires_reference": ".agents/instructions.md",
      "required_files": [
        ".codex/README.md"
      ]
    },
    {
      "id": "adapter-copilot",
      "role": "GitHub Copilot thin runtime adapter",
      "source": "runtime-adapters/copilot",
      "documentation_only": [],
      "requires_reference": ".agents/instructions.md",
      "required_files": [
        ".github/copilot-instructions.md",
        ".github/instructions/ai-workflow.instructions.md"
      ]
    },
    {
      "id": "adapter-claude",
      "role": "Claude Code thin runtime adapter",
      "source": "runtime-adapters/claude",
      "documentation_only": [],
      "requires_reference": ".agents/instructions.md",
      "required_files": [
        "CLAUDE.md"
      ]
    },
    {
      "id": "adapter-antigravity",
      "role": "Antigravity thin runtime adapter",
      "source": "runtime-adapters/antigravity",
      "documentation_only": [],
      "requires_reference": ".agents/instructions.md",
      "required_files": [
        "ANTIGRAVITY.md",
        ".antigravity/README.md"
      ]
    }
  ]
}