{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://all-metrics.local/agents/skills/registry.schema.json",
  "title": "All Metrics Skill Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "canonical_source",
    "derived_artifact",
    "generated_by",
    "skills",
    "pattern_skills"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "canonical_source": { "type": "string" },
    "derived_artifact": { "type": "boolean" },
    "generated_by": { "type": "string" },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    },
    "pattern_skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "class",
        "path",
        "trigger",
        "loading_posture",
        "key"
      ],
      "properties": {
        "name": { "type": "string" },
        "class": { "type": "string" },
        "path": { "type": "string" },
        "trigger": { "type": "string" },
        "loading_posture": { "type": "string" },
        "cost_hint": { "type": ["string", "null"] },
        "key": { "type": "string" },
        "runtime_notes": { "type": ["string", "null"] }
      }
    }
  }
}
